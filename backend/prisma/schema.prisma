  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])

  approval Approval @relation(fields: [approvalId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("approval_files")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  link      String?
  isRead    Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

model OtpVerification {
  id        String   @id @default(uuid())
  userId    String?
  email     String
  otp       String
  purpose   String
  isUsed    Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("otp_verifications")
}

model KnowledgeCategory {
  id          String              @id @default(uuid())
  name        String              @unique
  description String?
  icon        String?
  sortOrder   Int                 @default(0)
  isActive    Boolean             @default(true)
  parentId    String?
  parent      KnowledgeCategory?  @relation("KnowledgeCategoryParent", fields: [parentId], references: [id])
  children    KnowledgeCategory[] @relation("KnowledgeCategoryParent")
  articles    KnowledgeArticle[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([parentId])
  @@map("knowledge_categories")
}

enum KnowledgeArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model KnowledgeArticle {
  id           String                 @id @default(uuid())
  title        String
  content      String?
  status       KnowledgeArticleStatus @default(DRAFT)
  categoryId   String?
  category     KnowledgeCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags         String?
  createdById  String?
  createdBy    User?                  @relation("KnowledgeArticleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  publishedAt  DateTime?
  files        KnowledgeFile[]
  views        KnowledgeView[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([categoryId])
  @@index([status])
  @@index([createdById])
  @@map("knowledge_articles")
}

model KnowledgeFile {
  id          String           @id @default(uuid())
  articleId   String
  name        String
  fileUrl     String
  fileType    String?
  fileSize    Int?
  isVideo     Boolean          @default(false)
  sortOrder   Int              @default(0)
  article     KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())

  @@index([articleId])
  @@map("knowledge_files")
}

model KnowledgeView {
  id        String           @id @default(uuid())
  articleId String
  userId    String?
  user      User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  article   KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@index([articleId])
  @@index([userId])
  @@map("knowledge_views")
}

enum ReviewRating {
  ONE
  TWO
  THREE
  FOUR
  FIVE
}

enum AppraisalStatus {
  DRAFT
  SUBMITTED
  ACKNOWLEDGED
}

enum WarningType {
  VERBAL
  WRITTEN
  FINAL
}

enum WarningStatus {
  ACTIVE
  EXPIRED
  RESOLVED
}

model PerformanceReview {
  id             String       @id @default(uuid())
  employeeId     String
  reviewerId     String?
  reviewDate     DateTime
  rating         ReviewRating @default(THREE)
  feedback       String?
  goals          String?
  strengths      String?
  improvements   String?
  status         String       @default("DRAFT")
  submittedAt    DateTime?
  nextReviewDate DateTime?

  employee Employee @relation("ReviewEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer Employee? @relation("ReviewReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([reviewerId])
  @@map("performance_reviews")
}

model Appraisal {
  id             String          @id @default(uuid())
  employeeId     String
  reviewDate     DateTime
  reviewerId     String?
  currentCtc     Float?
  newCtc         Float?
  incrementPct   Float?
  rating         ReviewRating    @default(THREE)
  comments       String?
  status         AppraisalStatus @default(DRAFT)
  acknowledgedAt DateTime?
  effectiveDate  DateTime?

  employee Employee @relation("AppraisalEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer Employee? @relation("AppraisalReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
  @@map("appraisals")
}

model Promotion {
  id              String   @id @default(uuid())
  employeeId      String
  fromDesignation String?
  toDesignation   String?
  fromSalary      Float?
  toSalary        Float?
  effectiveDate   DateTime
  reason          String?
  approvedById    String?
  status          String   @default("APPROVED")

  employee  Employee? @relation("PromotionEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  approvedBy Employee? @relation("PromotionApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@map("promotions")
}

model Warning {
  id          String        @id @default(uuid())
  employeeId  String
  type        WarningType   @default(VERBAL)
  title       String
  description String?
  issuedById  String?
  status      WarningStatus @default(ACTIVE)
  issuedDate  DateTime
  expiresAt   DateTime?
  resolvedAt  DateTime?
  notes       String?

  employee Employee @relation("WarningEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  issuedBy Employee? @relation("WarningIssuedBy", fields: [issuedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@map("warnings")
}

model HrNote {
  id          String   @id @default(uuid())
  employeeId  String
  note        String
  createdById String?
  isPrivate   Boolean  @default(false)

  employee  Employee? @relation("HrNoteEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy Employee? @relation("HrNoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@map("hr_notes")
}

enum ComponentType {
  EARNING
  DEDUCTION
}

enum PayrollStatus {
  DRAFT
  PROCESSED
  CANCELLED
}

model SalaryComponent {
  id          String        @id @default(uuid())
  name        String        @unique
  type        ComponentType
  description String?
  isActive    Boolean       @default(true)
  sortOrder   Int           @default(0)

  employeeStructures EmployeeSalaryStructure[]
  payslipComponents  PayslipComponent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("salary_components")
}

model EmployeeSalaryStructure {
  id              String   @id @default(uuid())
  employeeId      String
  componentId     String
  amount          Float
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  isCurrent       Boolean  @default(true)

  employee  Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  component SalaryComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@unique([employeeId, componentId, effectiveFrom])
  @@map("employee_salary_structures")
}

model Payroll {
  id          String        @id @default(uuid())
  month       Int
  year        Int
  status      PayrollStatus @default(DRAFT)
  totalGross  Float         @default(0)
  totalDeductions Float    @default(0)
  totalNet    Float         @default(0)
  employeeCount Int         @default(0)
  processedAt DateTime?
  notes       String?

  payslips Payslip[]
  bonuses  Bonus[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, year])
  @@map("payrolls")
}

model Payslip {
  id              String   @id @default(uuid())
  payrollId       String
  employeeId      String
  grossPay        Float    @default(0)
  totalDeductions Float    @default(0)
  netPay          Float    @default(0)
  workingDays     Int      @default(0)
  presentDays     Int      @default(0)
  absentDays      Int      @default(0)
  leaveDays       Int      @default(0)
  remarks         String?

  payroll  Payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  components PayslipComponent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([payrollId, employeeId])
  @@index([payrollId])
  @@index([employeeId])
  @@map("payslips")
}

model PayslipComponent {
  id            String          @id @default(uuid())
  payslipId     String
  componentId   String
  amount        Float
  component     SalaryComponent @relation(fields: [componentId], references: [id])
  payslip       Payslip         @relation(fields: [payslipId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([payslipId, componentId])
  @@map("payslip_components")
}

enum BonusType {
  PERFORMANCE
  FESTIVAL
  REFERRAL
  SPOT
  ANNUAL
  OTHER
}

enum BonusStatus {
  APPROVED
  PAID
  CANCELLED
}

model Bonus {
  id          String      @id @default(uuid())
  employeeId  String
  type        BonusType   @default(PERFORMANCE)
  title       String
  description String?
  amount      Float
  currency    String      @default("INR")
  status      BonusStatus @default(APPROVED)
  approvedById String?
  paidAt      DateTime?
  payDate     DateTime?
  payrollId   String?
  payroll     Payroll?    @relation(fields: [payrollId], references: [id], onDelete: SetNull)

  employee  Employee  @relation("BonusEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  approvedBy Employee? @relation("BonusApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([payrollId])
  @@map("bonuses")
}
