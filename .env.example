# ============================================================
# AdScale One ERP — Root Docker Compose Environment Variables
# Copy this file to .env and fill in the values before running
# ============================================================

# PostgreSQL
POSTGRES_DB=adscale_erp
POSTGRES_USER=adscale_user
# REQUIRED: Set a strong password
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT
# REQUIRED: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHAR_HEX
JWT_EXPIRES_IN=7d

# AES-256-GCM Encryption Key for biometric API keys
# REQUIRED: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_GENERATE_RANDOM_64_CHAR_HEX

# Email (optional — OTP falls back to console log if not set)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=AdScale One ERP <no-reply@adscale.com>

# OTP
OTP_EXPIRES_MINUTES=10

# Frontend public URL for API calls (used at build time)
VITE_API_BASE_URL=http://YOUR_VPS_IP_OR_DOMAIN:5000/api

# Port mappings
FRONTEND_PORT=80

# CORS allowed origins (comma separated, no trailing slash)
ALLOWED_ORIGINS=http://localhost,http://YOUR_VPS_IP_OR_DOMAIN,http://187.127.134.114:30917
